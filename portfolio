<script>
function goTo(id) {
  var el = document.getElementById(id);
  if (!el) return;
  var navH = document.querySelector('nav').offsetHeight;
  var top = el.getBoundingClientRect().top + window.pageYOffset - navH - 16;
  window.scrollTo({ top: top, behavior: 'smooth' });
}

var navBtns = document.querySelectorAll('.nav-btn');
var allSections = ['hero','about','skills','experience','projects','education','contact'];

window.addEventListener('scroll', function() {
  var scrollY = window.scrollY + 120;
  var current = 'hero';
  allSections.forEach(function(id) {
    var el = document.getElementById(id);
    if (el && el.offsetTop <= scrollY) current = id;
  });
  navBtns.forEach(function(btn) {
    var id = btn.getAttribute('onclick').replace("goTo('","").replace("')","");
    btn.classList.toggle('active', id === current);
  });
});
</script>
